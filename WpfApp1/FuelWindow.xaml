<Page x:Class="WpfApp1.FuelWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="FuelWindow"
      Height="450"
      Width="800">

    <Grid>
        <!-- Gradientowe tło -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Offset="0" Color="Black" />
                <GradientStop Offset="1" Color="#FFF1A7A7" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Tytuł -->
        <Label
            Content="Ile litrów paliwa chciałbyś zatankować?"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0,50,0,0"
            FontFamily="Comic Sans MS"
            FontSize="20"
            Foreground="White" />

        <!-- Cena za litr -->
        <Label Content="ON (5,19 zł/L):"
               HorizontalAlignment="Left"
               Margin="205,120,0,0"
               VerticalAlignment="Top"
               FontFamily="Comic Sans MS"
               FontSize="18"
               Foreground="White"/>

        <!-- Pole do wpisania ilości litrów -->
        <TextBox x:Name="fuelInput"
                 Width="200"
                 Height="30"
                 HorizontalAlignment="Left"
                 Margin="400,123,0,0"
                 VerticalAlignment="Top"/>

        <!-- Stan konta -->
        <Label x:Name="moneyLabel"
               Content="Pieniądze: ..."
               HorizontalAlignment="Left"
               Margin="205,170,0,0"
               VerticalAlignment="Top"
               FontFamily="Comic Sans MS"
               FontSize="16"
               Foreground="White"/>

        <!-- Stan paliwa -->
        <Label x:Name="fuelLabel"
               Content="Paliwo: ..."
               HorizontalAlignment="Left"
               Margin="400,170,0,0"
               VerticalAlignment="Top"
               FontFamily="Comic Sans MS"
               FontSize="16"
               Foreground="White"/>

        <!-- Przycisk Dalej -->
        <Button x:Name="next"
                Content="Dalej"
                Width="140"
                Height="29"
                Background="#FFCF9776"
                HorizontalAlignment="Left"
                Margin="205,240,0,0"
                VerticalAlignment="Top"
                FontFamily="Comic Sans MS"
                FontSize="18"
                Click="next_Click"/>

        <!-- Przycisk Cofnij -->
        <Button x:Name="back"
                Content="Cofnij"
                Width="140"
                Height="29"
                Background="#FFCF9776"
                HorizontalAlignment="Left"
                Margin="455,240,0,0"
                VerticalAlignment="Top"
                FontFamily="Comic Sans MS"
                FontSize="18"
                Click="back_Click"/>
    </Grid>
</Page>
