<Page x:Class="WpfApp1.JurtalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="JurtalWindow" Height="450" Width="800">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Offset="0" Color="Black" />
                <GradientStop Offset="1" Color="#FFF1A7A7" />
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="5*" />
        </Grid.ColumnDefinitions>
        <Label
            Grid.Column="1"
            Width="262"
            Margin="136,15,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="#FFCF9776"
            Content="Wybierz Przeciwnika..."
            FontFamily="Comic Sans MS"
            FontSize="24" />
        
        <Button
            x:Name="Enemy1"
            Grid.Column="1"
            Width="150"
            Margin="192,93,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Content="Pijak"
            FontSize="22" 
            Click="Enemy1_Click" />
        <Button
            x:Name="Enemy2"
            Grid.Column="1"
            Width="150"
            Margin="192,158,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Content="Młodszy Dres"
            FontSize="22" 
            Click="Enemy2_Click" />
        <Button
            x:Name="Enemy3"
            Grid.Column="1"
            Width="150"
            Margin="192,223,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Content="Starszy Dres"
            FontSize="22" 
            Click="Enemy3_Click" />
        <Button
            x:Name="Enemy4"
            Grid.Column="1"
            Width="150"
            Margin="192,288,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Content="Gangster"
            FontSize="22" 
            Click="Enemy4_Click" />
        <Button
            x:Name="back"
            Grid.Column="1"
            Width="150"
            Margin="192,353,0,0"
            FontSize="22"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Content="Wróć" Click="back_Click" />
    </Grid>
</Page>
