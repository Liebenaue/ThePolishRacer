<Page
    x:Class="WpfApp1.window3"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfApp1"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="window3"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Offset="0" Color="Black" />
                <GradientStop Offset="1" Color="#FFF1A7A7" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Nagłówki -->
        <Label Margin="23,18,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#FFCF9776" Content="Twój bohater to:" FontFamily="Comic Sans MS" FontSize="18" />
        <Label Margin="420,20,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#FFCF9776" Content="Twój pojazd to:" FontFamily="Comic Sans MS" FontSize="18" />

        <!-- Imiona -->
        <TextBox x:Name="charName" Width="170" Height="35" Margin="223,20,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="15" Loaded="charName_Loaded" TextWrapping="Wrap" />
        <TextBox x:Name="carName" Width="170" Height="35" Margin="610,18,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="15" Loaded="carName_Loaded" TextWrapping="Wrap" />

        <!-- Lewa kolumna -->
        <Label Margin="23,80,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Wiek" Width="130" Height="28" FontSize="15"/>
        <TextBox x:Name="charAge" Width="120" Height="28" Margin="190,80,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" TextWrapping="Wrap" FontSize="15"/>

        <Label Margin="23,130,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Siła" Width="130" Height="28" FontSize="15"/>
        <TextBox x:Name="charStrength" Width="120" Height="28" Margin="190,130,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" TextWrapping="Wrap" FontSize="15"/>

        <Label Margin="23,177,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Content="PKT Życia Pojazdu" Width="130" Height="34" FontSize="15"/>
        <TextBox x:Name="charHP" Width="120" Height="28" Margin="190,183,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" TextWrapping="Wrap" FontSize="15"/>

        <Label Margin="23,233,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Opór" Width="130" Height="28" FontSize="15"/>
        <TextBox x:Name="charRes" Width="120" Height="28" Margin="190,233,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" TextWrapping="Wrap" FontSize="15"/>

        <Label Margin="23,284,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Max Prędkość (km/h)" Width="207" Height="28" FontSize="15"/>
        <TextBox x:Name="charSpeed" Width="120" Height="24" Margin="190,288,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" TextWrapping="Wrap" FontSize="15"/>

        <!-- Prawa kolumna -->
        <Label Margin="420,82,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Dni po urodzinach" Width="180" Height="28" FontSize="15"/>
        <TextBox x:Name="charAgeDays" Width="120" Height="28" Margin="610,82,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" TextWrapping="Wrap" FontSize="15"/>

        <Label Margin="420,127,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Masa Pojazdu (kg)" Width="180" Height="34" FontSize="15"/>
        <TextBox x:Name="charMass" Width="120" Height="28" Margin="610,130,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" TextWrapping="Wrap" FontSize="15"/>

        <Label Margin="420,180,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Pojemność Zbiornika (L)" Width="180" Height="28" FontSize="15"/>
        <TextBox x:Name="carFuelMass" Width="120" Height="28" Margin="610,183,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" TextWrapping="Wrap" FontSize="15"/>

        <Label Margin="420,233,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Zdolności Biegowe" Width="180" Height="33" FontSize="15"/>
        <TextBox x:Name="charRun" Width="120" Height="28" Margin="610,233,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" TextWrapping="Wrap" FontSize="15"/>

        <Label Margin="420,284,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Pieniądze (PLN)" Width="207" Height="28" FontSize="15"/>
        <TextBox x:Name="charMoney" Width="120" Height="28" Margin="610,284,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" TextWrapping="Wrap" FontSize="15"/>

        <!-- Przyciski -->
        <Button x:Name="back" Width="75" Margin="540,360,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Click="back_Click" Content="Wróć" FontSize="15"/>
        <Button Width="75" Margin="650,360,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Zapis" FontSize="15"/>
    </Grid>
</Page>