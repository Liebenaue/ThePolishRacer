<Page x:Class="WpfApp1.PrefightWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="PrefightWindow" Height="450" Width="800">
    <Grid>
        <Label 
            Content="Wybierz lokacje..." 
            Margin="0,66,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            FontSize="46"/>
        <Button 
            x:Name="yurtal" 
            Content="Jurtal sp. z. o. o." 
            Width="150"
            Margin="90,190,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            FontSize="26" Click="yurtal_Click" />
        <Button 
            x:Name="castle" 
            Content="Zamek" 
            Width="150"
            Margin="305,190,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            FontSize="26" />
        <Button 
            x:Name="back" 
            Content="Cofnij" 
            Width="150"
            Margin="520,190,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            FontSize="26" 
            Click="back_Click"/>
    </Grid>
</Page>
