<Page x:Class="WpfApp1.window2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:WpfApp1"
      mc:Ignorable="d"
      Title="window2"
      Height="450"
      Width="800">

    <Grid>
        <!-- Gradientowe tło jak w menu -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Offset="0" Color="Black" />
                <GradientStop Offset="1" Color="#FFF1A7A7" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Etykieta tytułowa -->
        <Label
            Content="Aby rozpocząć, musisz stworzyć głównego bohatera."
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0,20,0,0"
            FontFamily="Comic Sans MS"
            FontSize="20"
            Foreground="White" />

        <!-- Nazwa postaci -->
        <Label Content="Nazwa:"
               HorizontalAlignment="Left"
               Margin="205,80,0,0"
               VerticalAlignment="Top"
               FontFamily="Comic Sans MS"
               FontSize="16"
               Foreground="White"/>
        <TextBox x:Name="charName"
                 Width="200"
                 Height="30"
                 HorizontalAlignment="Left"
                 Margin="400,80,0,0"
                 VerticalAlignment="Top"/>

        <!-- Pojazd -->
        <Label Content="Pojazd (1-3):"
               HorizontalAlignment="Left"
               Margin="205,130,0,0"
               VerticalAlignment="Top"
               FontFamily="Comic Sans MS"
               FontSize="16"
               Foreground="White"/>
        <TextBox x:Name="charCar"
                 Width="200"
                 Height="30"
                 HorizontalAlignment="Left"
                 Margin="400,130,0,0"
                 VerticalAlignment="Top"/>

        <!-- Klan -->
        <Label Content="Klan (1-3):"
               HorizontalAlignment="Left"
               Margin="205,180,0,0"
               VerticalAlignment="Top"
               FontFamily="Comic Sans MS"
               FontSize="16"
               Foreground="White"/>
        <TextBox x:Name="charClan"
                 Width="200"
                 Height="30"
                 HorizontalAlignment="Left"
                 Margin="400,180,0,0"
                 VerticalAlignment="Top"/>

        <!-- Przycisk Dalej -->
        <Button x:Name="next"
                Content="Dalej"
                Width="140"
                Height="29"
                Background="#FFCF9776"
                HorizontalAlignment="Left"
                Margin="205,250,0,0"
                VerticalAlignment="Top"
                FontFamily="Comic Sans MS"
                FontSize="18"
                Click="next_Click"/>

        <!-- Przycisk Cofnij -->
        <Button x:Name="back"
                Content="Cofnij"
                Width="140"
                Height="29"
                Background="#FFCF9776"
                HorizontalAlignment="Left"
                Margin="455,250,0,0"
                VerticalAlignment="Top"
                FontFamily="Comic Sans MS"
                FontSize="18"
                Click="back_Click"/>
    </Grid>
</Page>
